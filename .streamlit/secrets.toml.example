# Copy these into the Streamlit Community Cloud dashboard → App → Settings →
# Secrets (NOT committed to git). Local testing: copy to secrets.toml.
#
ANTHROPIC_API_KEY = "sk-ant-..."   # the key that pays for searches
GUSTAVE_PASSCODE  = "choose-a-word" # friends type this to get in
GUSTAVE_SESSION_CAP = "25"          # max searches per visitor per session
GUSTAVE_DAILY_CAP   = "300"         # max searches/day across everyone (bill ceiling)
